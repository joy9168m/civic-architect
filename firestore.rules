rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == role;
    }

    function isWorker() {
      return hasRole('worker');
    }

    function isAssignedWorker() {
      return isWorker() && resource.data.assignedWorkerId == request.auth.uid;
    }

    function isAdmin() {
      return hasRole('admin') || hasRole('dev');
    }

    function isDev() {
      return hasRole('dev');
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['citizen', 'admin', 'dev', 'worker'];
    }

    function isValidIssue(data) {
      return data.keys().hasAll(['title', 'category', 'reportedAt', 'reportedBy']) &&
             data.title is string && data.title.size() < 200 &&
             data.category is string &&
             data.reportedBy == request.auth.uid;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == userId && isValidUser(request.resource.data) &&
        (
          (request.auth.token.email == "joydeepmondal9168j@gmail.com" && request.resource.data.role == 'admin') ||
          (request.auth.token.email == "sourish@gmail.com" && request.resource.data.role == 'dev') ||
          ((request.resource.data.role == 'citizen' || request.resource.data.role == 'worker') && request.auth.token.email != "joydeepmondal9168j@gmail.com" && request.auth.token.email != "sourish@gmail.com")
        );
      allow update: if isOwner(userId) || isAdmin();
    }

    match /issues/{issueId} {
      allow read: if true;
      allow create: if (isAuthenticated() && isValidIssue(request.resource.data)) || isAdmin() || request.auth.token.email == "joydeepmondal9168j@gmail.com";
      allow update: if isAdmin() || (isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['upvotes', 'upvotedBy'])) || (isAssignedWorker() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'resolutionImageUrl']));
      allow delete: if isAdmin();
    }
    
    match /test/connection {
      allow read: if true;
    }
  }
}
